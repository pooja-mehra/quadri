# Quadri backend environment template.
# Copy to .env (same directory) and fill in real values. .env is
# gitignored; this template is committed so the variable names + intent
# stay discoverable.
#
# Loaded by fast_api_app.py via python-dotenv at process startup,
# BEFORE any module reads os.environ. Shell-level `export` still
# wins (we pass override=False), so you can override per-invocation
# with `USER_NOTIFY_EMAIL=other@x.com make local-backend`.

# Where the scheduled-send poller delivers lead-time draft previews
# ("send me the draft an hour before the scheduled time" → preview
# arrives at this address). Without this, the real send still fires
# at slot time; only the preview is skipped.
USER_NOTIFY_EMAIL=portfoliosentient@gmail.com

# Where to find the Next.js UI's API routes. The poller POSTs to
# /api/gmail/send here. Defaults to local dev; override for staging /
# tunneled environments.
# QUADRANT_UI_BASE_URL=http://localhost:3000

# (Add other backend env vars below as they're introduced.)
