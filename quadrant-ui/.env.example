# Quadri UI environment template.
# Copy to .env.local (same directory) for local dev. .env.local is
# gitignored; this template is committed so the variable names + intent
# stay discoverable. For Vercel, set these in Project Settings → Environment
# Variables (Production + Preview + Development scopes).

# --- BigQuery / project ---
# GCP project that owns the `quadrant` BigQuery dataset.
GCP_PROJECT=quadrant-495518
QUADRANT_DATASET=quadrant
QUADRANT_USER_ID=demo_user

# --- Service-account auth (Vercel + Cloud Run only) ---
# Paste the ENTIRE service-account JSON here as a single line. The
# BigQuery client parses it at runtime. Leave empty for local dev so
# Application Default Credentials (gcloud auth application-default
# login) are used instead.
#
# The SA needs: BigQuery Data Editor + Job User on the quadrant dataset.
# GCP_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...","client_email":"..."}

# --- Agent backend ---
# Where the FastAPI/ADK agent lives. Local dev → http://localhost:8000.
# Hosted demo → the Cloud Run URL.
AGENT_BACKEND_URL=http://localhost:8000
AGENT_APP_NAME=app

# --- Google OAuth (live mode only — skipped in demo mode) ---
# Set these to your OAuth client_id/secret if you want the live
# "Connect Google" flow to work. In demo mode they're not read.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- Demo mode (hosted submission) ---
# Set both to "true" on the hosted Vercel project so judges don't see
# a Connect Google CTA and clicking Send / Sync no-ops cleanly. Local
# dev should leave them unset / false.
# QUADRI_DEMO_MODE=true
# NEXT_PUBLIC_QUADRI_DEMO_MODE=true

# --- Local notes CSV ---
# Where appendNoteToLocalCsv writes per-Done rows in dev. Demo mode
# skips the write entirely (Vercel filesystem is read-only).
# QUADRI_NOTES_FILE=/Users/yourname/Documents/quadri-notes.csv
